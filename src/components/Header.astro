---
interface Props {
  lang: string;
  currentPath?: string;
}

const { lang, currentPath = '' } = Astro.props;

const nav = [
  { href: `/${lang}/`, labelKey: 'home' },
  { href: `/${lang}/about`, labelKey: 'about' },
  { href: `/${lang}/services`, labelKey: 'services' },
  { href: `/${lang}/contact`, labelKey: 'contact' },
];

const t = await import(`../i18n/${lang}.json`).then(m => m.default);
const otherLang = lang === 'de' ? 'en' : 'de';
const pathSuffix = currentPath.replace(new RegExp(`^/${lang}/?`), '').replace(/^\//, '') || '';
const langSwitchHref = pathSuffix ? `/${otherLang}/${pathSuffix}` : `/${otherLang}/`;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream/95 backdrop-blur-md border-b border-navy/5">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={`/${lang}/`} class="font-heading text-xl font-semibold text-navy hover:text-teal transition-colors">
      MareSphere
    </a>
    <div class="flex items-center gap-8">
      <ul class="hidden md:flex items-center gap-6">
        {nav.map((item) => (
          <li>
            <a href={item.href} class="text-navy/80 hover:text-teal font-medium transition-colors">
              {t.nav[item.labelKey]}
            </a>
          </li>
        ))}
      </ul>
      <a href={langSwitchHref} class="hidden md:inline text-sm font-medium text-navy/70 hover:text-teal transition-colors uppercase tracking-wider">
        {otherLang === 'de' ? 'DE' : 'EN'}
      </a>
      <label for="mobile-menu-toggle" class="md:hidden p-2 cursor-pointer text-navy hover:text-teal" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </nav>
  <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" />
  <div class="md:hidden hidden peer-checked:block bg-cream border-t border-navy/5 px-6 py-4">
    <ul class="space-y-4">
      {nav.map((item) => (
        <li>
          <a href={item.href} class="block text-navy/80 hover:text-teal font-medium py-2">
            {t.nav[item.labelKey]}
          </a>
        </li>
      ))}
      <li>
        <a href={langSwitchHref} class="block text-navy/70 hover:text-teal font-medium py-2 uppercase tracking-wider">
          {otherLang === 'de' ? 'DE' : 'EN'}
        </a>
      </li>
    </ul>
  </div>
</header>
