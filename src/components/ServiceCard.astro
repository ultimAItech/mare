---
interface Props {
  title: string;
  description: string;
  href: string;
  lang: string;
  linkText?: string;
  image?: string;
}

const { title, description, href, lang, linkText, image } = Astro.props;
const t = await import(`../i18n/${lang}.json`).then(m => m.default);
const displayLinkText = linkText ?? t.services?.learnMore ?? t.home?.learnMore ?? 'Mehr erfahren';
---

<article class="bg-white rounded-xl border border-navy/10 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col h-full overflow-hidden group">
  {image && (
    <div class="h-48 overflow-hidden relative">
      <div class="absolute inset-0 bg-navy/20 group-hover:bg-navy/0 transition-colors duration-300 z-10"></div>
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    </div>
  )}
  <div class="p-6 flex flex-col flex-grow">
    <h3 class="font-heading text-xl font-semibold text-navy mb-3 group-hover:text-teal transition-colors">{title}</h3>
    <p class="text-navy/80 flex-grow mb-4">{description}</p>
    <a href={href} class="text-teal font-medium hover:text-teal-light inline-flex items-center gap-2">
      {displayLinkText}
      <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
    </a>
  </div>
</article>
