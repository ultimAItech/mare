---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = await import(`../i18n/${lang}.json`).then(m => m.default);
---

<form class="space-y-6" action="#" method="POST">
  <div>
    <label for="name" class="block text-sm font-medium text-navy mb-2">{t.contact.formName}</label>
    <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-navy/20 bg-white focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all" />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-navy mb-2">{t.contact.formEmail}</label>
    <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-navy/20 bg-white focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all" />
  </div>
  <div>
    <label for="service" class="block text-sm font-medium text-navy mb-2">{t.contact.formService}</label>
    <select id="service" name="service" class="w-full px-4 py-3 rounded-lg border border-navy/20 bg-white focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all">
      <option value="">{t.contact.formServicePlaceholder}</option>
      <option value="tech">{t.contact.services.tech}</option>
      <option value="emergency">{t.contact.services.emergency}</option>
      <option value="parts">{t.contact.services.parts}</option>
      <option value="docs">{t.contact.services.docs}</option>
      <option value="management">{t.contact.services.management}</option>
      <option value="modules">{t.contact.services.modules}</option>
    </select>
  </div>
  <div>
    <label for="message" class="block text-sm font-medium text-navy mb-2">{t.contact.formMessage}</label>
    <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-navy/20 bg-white focus:border-teal focus:ring-2 focus:ring-teal/20 outline-none transition-all resize-none"></textarea>
  </div>
  <button type="submit" class="w-full md:w-auto px-8 py-3 bg-teal text-cream font-medium rounded-lg hover:bg-teal-light transition-colors">
    {t.contact.formSubmit}
  </button>
</form>
