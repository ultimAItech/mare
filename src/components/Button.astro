---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const variants = {
  primary: 'bg-teal text-cream hover:bg-teal-light border-teal',
  secondary: 'bg-navy text-cream hover:bg-navy-light border-navy',
  outline: 'bg-transparent border-2 border-navy text-navy hover:bg-navy hover:text-cream border-navy',
};
---

<a href={href} class={`inline-flex items-center justify-center px-6 py-3 font-medium rounded-lg transition-all duration-200 ${variants[variant]} ${className}`}>
  <slot />
</a>
