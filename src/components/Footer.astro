---
interface Props {
  lang: string;
}

const { lang } = Astro.props;

const t = await import(`../i18n/${lang}.json`).then(m => m.default);

const navLinks = [
  { href: `/${lang}/`, labelKey: 'home' },
  { href: `/${lang}/about`, labelKey: 'about' },
  { href: `/${lang}/services`, labelKey: 'services' },
  { href: `/${lang}/contact`, labelKey: 'contact' },
];

const serviceLinks = [
  { href: `/${lang}/services`, labelKey: 'service1Title' },
  { href: `/${lang}/services`, labelKey: 'service2Title' },
  { href: `/${lang}/services`, labelKey: 'service3Title' },
];
---

<footer class="bg-navy text-cream mt-24">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-12">
      <div>
        <p class="font-heading text-2xl font-semibold mb-2">MareSphere</p>
        <p class="text-cream/80 text-sm">{t.footer.tagline}</p>
      </div>
      <div>
        <h4 class="font-heading font-semibold mb-4 text-gold">{t.footer.nav}</h4>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-cream/80 hover:text-cream transition-colors">
                {t.nav[link.labelKey]}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading font-semibold mb-4 text-gold">{t.footer.services}</h4>
        <ul class="space-y-2">
          <li><a href={`/${lang}/services`} class="text-cream/80 hover:text-cream transition-colors">{t.services.service1Title}</a></li>
          <li><a href={`/${lang}/services`} class="text-cream/80 hover:text-cream transition-colors">{t.services.service2Title}</a></li>
          <li><a href={`/${lang}/services`} class="text-cream/80 hover:text-cream transition-colors">{t.services.service3Title}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-cream/20 flex flex-col md:flex-row justify-between items-center gap-4">
      <a href={`/${lang}/agb`} class="text-cream/60 hover:text-cream text-sm transition-colors">{t.footer.agb}</a>
      <p class="text-cream/60 text-sm">{t.footer.copyright}</p>
    </div>
  </div>
</footer>
