---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import ServiceCard from '../../components/ServiceCard.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'de' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
---

<BaseLayout title={t.home.title} description={t.home.heroSubtitle} lang={lang}>
  <div>
    <section class="relative min-h-[100vh] flex flex-col justify-center overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 w-full h-full z-0">
        <img 
          src="/assets/images/hero.jpeg" 
          alt="MareSphere Maritime Background" 
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Dark overlay to ensure text readability -->
        <div class="absolute inset-0 bg-navy/60 bg-gradient-to-b from-navy/20 to-cream/40"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 flex flex-col items-center text-center">
        <img src="/assets/images/Logo_No_Background.png" alt="MareSphere Logo" class="h-[130px] md:h-[162px] mb-8 object-contain drop-shadow-lg" />
        <h1 class="font-heading text-5xl md:text-7xl font-bold text-cream mb-4 drop-shadow-lg">{t.home.title}</h1>
        <p class="font-heading text-2xl md:text-3xl text-teal-light mb-6 drop-shadow-md">{t.home.tagline}</p>
        <p class="text-xl text-cream/90 max-w-2xl drop-shadow-sm">{t.home.heroSubtitle}</p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy mb-6">{t.home.partnerTitle}</h2>
          <p class="text-lg text-navy/80">{t.home.partnerText}</p>
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg border border-navy/5">
          <img src="/assets/images/modern_cargo_ship.png" alt="Modern cargo ship" class="w-full h-auto object-cover aspect-[4/3] hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <Card>
          <h3 class="font-heading text-xl font-semibold text-navy mb-3">{t.home.value1Title}</h3>
          <p class="text-navy/80">{t.home.value1Text}</p>
        </Card>
        <Card>
          <h3 class="font-heading text-xl font-semibold text-navy mb-3">{t.home.value2Title}</h3>
          <p class="text-navy/80">{t.home.value2Text}</p>
        </Card>
        <Card>
          <h3 class="font-heading text-xl font-semibold text-navy mb-3">{t.home.value3Title}</h3>
          <p class="text-navy/80">{t.home.value3Text}</p>
        </Card>
      </div>
    </section>

    <section class="bg-navy text-cream py-20">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">{t.home.expertiseTitle}</h2>
        <p class="text-cream/80 mb-12">{t.home.expertiseSubtitle}</p>
        <div class="grid md:grid-cols-3 gap-8">
          <ServiceCard 
            title={t.home.service1Title} 
            description={t.home.service1Text} 
            href={`/${lang}/services/nautisch-technische-koordination`} 
            image={(t.serviceDetails as any)?.['nautisch-technische-koordination']?.image}
            lang={lang} 
            linkText={t.home.allServices} 
          />
          <ServiceCard 
            title={t.home.service2Title} 
            description={t.home.service2Text} 
            href={`/${lang}/services/maritime-notfallkoordination`} 
            image={(t.serviceDetails as any)?.['maritime-notfallkoordination']?.image}
            lang={lang} 
            linkText={t.home.allServices} 
          />
          <ServiceCard 
            title={t.home.service3Title} 
            description={t.home.service3Text} 
            href={`/${lang}/services/ersatzteilbeschaffung`} 
            image={(t.serviceDetails as any)?.['ersatzteilbeschaffung']?.image}
            lang={lang} 
            linkText={t.home.allServices} 
          />
        </div>
        <div class="mt-12">
          <Button href={`/${lang}/services`}>{t.home.allServices}</Button>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-20">
      <blockquote class="font-heading text-2xl md:text-3xl text-navy/90 italic max-w-3xl mx-auto text-center">
        "{t.home.quote}"
      </blockquote>
      <p class="text-center text-navy/70 mt-4">— MareSphere</p>
    </section>

    <section class="bg-teal/10 py-20">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy mb-6">{t.home.ctaTitle}</h2>
        <p class="text-lg text-navy/80 mb-8 max-w-2xl mx-auto">{t.home.ctaText}</p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button href={`/${lang}/contact`}>{t.home.contactCta}</Button>
          <Button href={`/${lang}/services`} variant="outline">{t.home.learnMore}</Button>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
