---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'de' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);

const services = [
  { id: 'nautisch-technische-koordination', title: t.services.service1Title, description: t.services.service1Text, image: (t.serviceDetails as any)?.['nautisch-technische-koordination']?.image },
  { id: 'maritime-notfallkoordination', title: t.services.service2Title, description: t.services.service2Text, image: (t.serviceDetails as any)?.['maritime-notfallkoordination']?.image },
  { id: 'ersatzteilbeschaffung', title: t.services.service3Title, description: t.services.service3Text, image: (t.serviceDetails as any)?.['ersatzteilbeschaffung']?.image },
  { id: 'maritime-services', title: t.services.service4Title, description: t.services.service4Text, image: (t.serviceDetails as any)?.['maritime-services']?.image },
  { id: 'dokumentations-zertifikatsmanagement', title: t.services.service5Title, description: t.services.service5Text, image: (t.serviceDetails as any)?.['dokumentations-zertifikatsmanagement']?.image },
  { id: 'bereederungsmanagement', title: t.services.service6Title, description: t.services.service6Text, image: (t.serviceDetails as any)?.['bereederungsmanagement']?.image },
];
---

<BaseLayout title={t.services.title} description={t.services.subtitle} lang={lang}>
  <div>
    <section class="relative min-h-[50vh] flex flex-col justify-center overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 w-full h-full z-0">
        <img 
          src="/assets/images/global_shipping_network.png" 
          alt="MareSphere Background" 
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Dark overlay to ensure text readability -->
        <div class="absolute inset-0 bg-navy/60 bg-gradient-to-b from-navy/20 to-cream/20"></div>
      </div>
      <div class="relative z-10 max-w-6xl mx-auto px-6 pt-20 flex flex-col items-start">
        <img src="/assets/images/Logo_No_Background.png" alt="MareSphere Logo" class="h-16 md:h-24 mb-6 object-contain drop-shadow-lg" />
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 drop-shadow-lg">{t.services.title}</h1>
        <p class="font-heading text-xl text-teal-light drop-shadow-md">{t.services.subtitle}</p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard 
            title={service.title} 
            description={service.description} 
            href={service.noPage ? `/${lang}/contact` : `/${lang}/services/${service.id}`} 
            image={service.image}
            lang={lang} 
          />
        ))}
      </div>

      <section class="mt-20 bg-teal/10 py-12 rounded-xl text-center">
        <h2 class="font-heading text-2xl font-bold text-navy mb-4">{t.services.ctaTitle}</h2>
        <p class="text-navy/80 mb-6 max-w-2xl mx-auto">{t.services.ctaText}</p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button href={`/${lang}/contact`}>{t.services.contactCta}</Button>
          <Button href={`/${lang}/`} variant="outline">{t.services.backHome}</Button>
        </div>
      </section>
    </section>
  </div>
</BaseLayout>
