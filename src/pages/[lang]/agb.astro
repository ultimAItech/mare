---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'de' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
---

<BaseLayout title={t.agb.title} description={t.agb.placeholder} lang={lang}>
  <div class="pt-20">
    <section class="py-16 bg-gradient-to-b from-navy/5 to-transparent">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-navy mb-4">{t.agb.title}</h1>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-16">
      <p class="text-navy/80">{t.agb.placeholder}</p>
    </section>
  </div>
</BaseLayout>
