---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'de' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
---

<BaseLayout title={t.contact.title} description={t.contact.subtitle} lang={lang}>
  <div>
    <section class="relative min-h-[50vh] flex flex-col justify-center overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 w-full h-full z-0">
        <img 
          src="/assets/images/global_shipping_network.png" 
          alt="MareSphere Background" 
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Dark overlay to ensure text readability -->
        <div class="absolute inset-0 bg-navy/60 bg-gradient-to-b from-navy/20 to-cream/20"></div>
      </div>
      <div class="relative z-10 max-w-6xl mx-auto px-6 pt-20">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 drop-shadow-lg">{t.contact.title}</h1>
        <p class="font-heading text-xl text-teal-light drop-shadow-md">{t.contact.subtitle}</p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <h2 class="font-heading text-2xl font-semibold text-navy mb-6">{t.contact.contactPerson}</h2>
          <div class="space-y-6 text-navy/80">
            <div>
              <p class="text-sm font-medium text-navy mb-1">{t.contact.contactPerson}</p>
              <p>Finn Burchard</p>
            </div>
            <div>
              <p class="text-sm font-medium text-navy mb-1">{t.contact.phone}</p>
              <a href="tel:+491727905628" class="hover:text-teal transition-colors">+49 172 7905628</a>
            </div>
            <div>
              <p class="text-sm font-medium text-navy mb-1">{t.contact.email}</p>
              <a href="mailto:info@maresphere.com" class="hover:text-teal transition-colors">info@maresphere.com</a>
            </div>
            <div>
              <p class="text-sm font-medium text-navy mb-1">{t.contact.address}</p>
              <p>Schwalbenweg 4<br />18184 Roggetin</p>
            </div>
            <div>
              <p class="text-sm font-medium text-navy mb-1">{t.contact.hours}</p>
              <p>{t.contact.hoursValue}</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl border border-navy/10 p-8 shadow-sm">
          <h2 class="font-heading text-2xl font-semibold text-navy mb-6">{t.contact.formTitle}</h2>
          <ContactForm lang={lang} />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
