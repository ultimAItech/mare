---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';

export async function getStaticPaths() {
  const de = await import('../../../i18n/de.json').then(m => m.default);
  const en = await import('../../../i18n/en.json').then(m => m.default);
  
  const langs = ['de', 'en'];
  const paths = [];
  
  for (const lang of langs) {
    const data = lang === 'de' ? de : en;
    const services = Object.keys(data.serviceDetails || {});
    for (const id of services) {
      paths.push({
        params: { lang, id },
        props: { service: (data.serviceDetails as any)[id] }
      });
    }
  }
  
  return paths;
}

const { lang, id } = Astro.params;
const { service } = Astro.props;
const t = await import(`../../../i18n/${lang}.json`).then(m => m.default);
---

<BaseLayout title={service.title} description={service.subtitle} lang={lang}>
  <div>
    <section class="relative min-h-[50vh] flex flex-col justify-center overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 w-full h-full z-0">
        <img 
          src="/assets/images/modern_cargo_ship.png" 
          alt={`${service.title} Background`} 
          class="absolute inset-0 w-full h-full object-cover"
        />
        <!-- Dark overlay to ensure text readability -->
        <div class="absolute inset-0 bg-navy/60 bg-gradient-to-b from-navy/20 to-cream/20"></div>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center pt-20">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 drop-shadow-lg">{service.title}</h1>
        <p class="font-heading text-xl text-teal-light drop-shadow-md">{service.subtitle}</p>
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 py-16">
      <div class="prose prose-lg prose-navy max-w-none text-navy/80">
        <p class="text-xl leading-relaxed mb-12">{service.intro}</p>
        
        <div class="space-y-8 mb-16">
          {service.features.map((feature: any) => (
            <div class="bg-white p-6 rounded-xl border border-navy/10 shadow-sm hover:shadow-md transition-shadow">
              <h3 class="font-heading text-xl font-semibold text-navy mb-3">{feature.title}</h3>
              <p class="m-0 text-navy/80">{feature.description}</p>
            </div>
          ))}
        </div>
        
        {service.conclusion && (
           <div class="bg-teal/10 p-8 rounded-xl font-medium text-navy/90">
             {service.conclusion.split('\n\n').map((paragraph: string) => (
               <p class="mb-4 last:mb-0">{paragraph}</p>
             ))}
           </div>
        )}
      </div>

      <div class="mt-16 flex flex-wrap gap-4 justify-center">
        <Button href={`/${lang}/contact`}>{t.services.contactCta}</Button>
        <Button href={`/${lang}/services`} variant="outline">{t.services.backHome}</Button>
      </div>
    </section>
  </div>
</BaseLayout>
